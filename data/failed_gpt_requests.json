-----------------------------------------------------------------\n\ndef vector_in_vulnerable(data: bytes) -> object:\n    \"\"\"\n    Reproduction simplifiée du comportement vulnérable.\n    Le driver décode la réponse du serveur et appelle eval() sans validation.\n    \"\"\"\n    raw = data.decode(\"utf-8\")\n    print(f\"[CLIENT] Data recieved from server : {raw}\")\n    print(\"[CLIENT] Calling eval() on recieved data...\")\n    # FAILLE : eval() exécute tout code Python retourné par le serveur\n    result = eval(raw)  # noqa: S307\n    return result\n\n\ndef vector_in_safe(data: bytes) -> list:\n    \"\"\"\n    Version corrigée (≥ 2.1.14) : utilise ast.literal_eval() ou un parseur\n    dédié qui n'exécute pas de code arbitraire.\n    \"\"\"\n    import ast\n    raw = data.decode(\"utf-8\")\n    print(f\"[CLIENT] Data recieved from server : {raw}\")\n    print(\"[CLIENT] Calling ast.literal_eval() (version corrected)...\")\n    try:\n        result = ast.literal_eval(raw)\n        return result\n    except (ValueError, SyntaxError) as e:\n        raise ValueError(f\"Invalid or malicious server response : {e}\") from e\n\n\n# ---------------------------------------------------------------------------\n# Démonstration\n# ---------------------------------------------------------------------------\n\ndef connect_and_receive() -> bytes:\n    \"\"\"Connects to the fake server and retrieves the response.\"\"\"\n    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:\n        print(f\"[CLIENT] Connected to {HOST}:{PORT}...\")\n        s.connect((HOST, PORT))\n        s.sendall(b\"SELECT * FROM test_table;\")\n        data = s.recv(4096)\n    return data\n\n\"\"\"\nGUI\n\"\"\"\n\nwindow = tk.Tk()\n\nwindow.geometry(\"700x400\")\nwindow.title(\"Client Program\")\nwindow.minsize(400,300)\n\n\nquery_string = tk.StringVar()\n\nlabel = ttk.Label(master=window, text = \"Customer Search\", font=(\"Arial\",24))\n\ndef get_query():\n    user_input = query_string.get()   